# Frontend service for Railway: builds the Vite SPA and serves it.
# VITE_API_URL is baked in at build time (point it at the API service's public URL).
FROM node:22-slim AS build
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY . .
ARG VITE_API_URL
ENV VITE_API_URL=$VITE_API_URL
RUN npm run build

FROM node:22-slim
WORKDIR /app
COPY --from=build /app/dist ./dist
COPY --from=build /app/node_modules ./node_modules
COPY --from=build /app/package.json ./package.json
COPY server/static.js ./server/static.js
ENV NODE_ENV=production
ENV PORT=8080
EXPOSE 8080
CMD ["node", "server/static.js"]
