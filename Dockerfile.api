# Backend API service for Railway (the Express + Postgres + WebSocket server).
FROM node:22-slim

WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci --omit=dev
COPY server ./server

ENV NODE_ENV=production
ENV PORT=8787
EXPOSE 8787

# Provide DATABASE_URL (Railway Postgres) and JWT_SECRET via service variables.
CMD ["node", "server/index.js"]
