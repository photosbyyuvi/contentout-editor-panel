# ── Frontend ──
# Point the SPA at the backend to enable the real (auth + database) mode.
# Leave unset to run the zero-config in-memory demo instead.
VITE_API_URL=http://localhost:8787

# ── Backend (server/) ──
PORT=8787
# REQUIRED in production: a long, random value that signs sessions.
JWT_SECRET=replace-with-a-long-random-string
NODE_ENV=development

# Clean launch: seed only the owner + clients (no demo team/projects) when "false".
SEED_DEMO=true
# The real Owner account created on first boot (used when seeding):
# OWNER_EMAIL=you@yourstudio.com
# OWNER_PASSWORD=choose-a-strong-password
# OWNER_NAME=Your Name

# Where the frontend is hosted (used to build invite links) and which origins may call the API:
FRONTEND_URL=http://localhost:5173
# ALLOWED_ORIGINS=https://portal.yourstudio.com   # comma-separated; unset = allow all (dev only)

# Local SQLite path (default: server/data/portal.db). In prod, mount a volume:
# SQLITE_PATH=/data/portal.db

# Optional integrations — each degrades gracefully (logged) when unset:
# ANTHROPIC_API_KEY=sk-ant-...                 # live AI Mode (claude-sonnet-4-6)
# RESEND_API_KEY=re_...                        # real notification emails
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
