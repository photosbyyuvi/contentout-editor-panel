# ── Frontend ──
# Point the SPA at the backend to enable the real (auth + database) mode.
# Leave unset to run the zero-config in-memory demo instead.
VITE_API_URL=http://localhost:8787

# ── Backend (server/) ──
PORT=8787
# Use a long, random value in production. Sessions are signed with this.
JWT_SECRET=replace-with-a-long-random-string
# Local SQLite path (default: server/data/portal.db). For production use managed
# Postgres instead — see DEPLOYMENT.md.
# SQLITE_PATH=/data/portal.db

# Optional integrations — each degrades gracefully (logged) when unset:
# ANTHROPIC_API_KEY=sk-ant-...                 # live AI Mode (claude-sonnet-4-6)
# RESEND_API_KEY=re_...                        # real notification emails
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
